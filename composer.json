{
  "name": "zeroseven/z7-semantilizer",
  "license": "GPL-2.0-only",
  "type": "typo3-cms-extension",
  "description": "Simplify your semantic heading structure.",
  "authors": [
    {
      "name": "zeroseven design studios GmbH",
      "email": "typo3@zeroseven.de",
      "homepage": "https://www.zeroseven.de/",
      "role": "Company"
    },
    {
      "name": "Raphael Thanner",
      "role": "Developer"
    },
    {
      "name": "Sebastian Rosskopf",
      "role": "Developer"
    }
  ],
  "support": {
    "issues": "https://github.com/zeroseven/z7_semantilizer/issues",
    "docs": "https://github.com/zeroseven/z7_semantilizer/blob/master/README.md"
  },
  "require": {
    "php": "^8.3",
    "typo3/cms-core": "^13.1 || ^14.0",
    "ext-json": "*"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3",
    "php-parallel-lint/php-parallel-lint": "^1.2",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpunit/phpunit": "^11",
    "typo3/cms-backend": "^13.1 || ^14.0",
    "typo3/cms-fluid": "^13.1 || ^14.0",
    "typo3/cms-fluid-styled-content": "^13.1 || ^14.0",
    "typo3/cms-frontend": "^13.1 || ^14.0",
    "typo3/cms-install": "^13.1 || ^14.0",
    "typo3/testing-framework": "^8",
    "zeroseven/z7-semantilizer-dev": "@dev"
  },
  "repositories": [
    {
      "type": "path",
      "url": "Build/z7_semantilizer_dev",
      "options": {
        "symlink": true
      }
    }
  ],
  "suggest": {
    "typo3/cms-fluid-styled-content": "*"
  },
  "autoload": {
    "psr-4": {
      "Zeroseven\\Semantilizer\\": "Classes"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Zeroseven\\Semantilizer\\Tests\\": "Tests/"
    }
  },
  "config": {
    "vendor-dir": ".build/vendor",
    "bin-dir": ".build/bin",
    "web-dir": ".build/public",
    "platform": {
      "php": "8.3.0"
    },
    "sort-packages": true,
    "allow-plugins": {
      "typo3/class-alias-loader": true,
      "typo3/cms-composer-installers": true
    }
  },
  "scripts": {
    "test:unit": ".build/bin/phpunit -c phpunit.unit.xml --no-coverage",
    "test:functional": ".build/bin/phpunit -c phpunit.functional.xml --no-coverage",
    "test:all": [
      "@test:unit",
      "@test:functional"
    ],
    "cs:fix": ".build/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php",
    "cs:check": ".build/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff",
    "phpstan": ".build/bin/phpstan analyse --memory-limit=512M",
    "lint:php": [
      "@phpstan",
      "@cs:check"
    ],
    "test": [
      "@lint:php",
      "@test:unit"
    ],
    "test-php-lint": [
      ".build/bin/parallel-lint ./Classes/",
      ".build/bin/parallel-lint ./Configuration/"
    ],
    "prepare-release": [
      "rm .editorconfig",
      "rm .gitattributes",
      "rm .gitignore",
      "rm .gitlab-ci.yml",
      "rm -rf .github",
      "rm -rf .ddev",
      "rm -rf Build",
      "rm -rf Tests",
      "rm -rf scripts",
      "rm .nvmrc",
      "rm .php-cs-fixer.php",
      "rm .php-cs-fixer.dist.php",
      "rm phpstan.neon",
      "rm phpstan-bootstrap.php",
      "rm phpunit.unit.xml",
      "rm phpunit.functional.xml",
      "rm gulpfile.js",
      "rm package-lock.json",
      "rm package.json",
      "rm tsconfig.json"
    ]
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "z7_semantilizer",
      "web-dir": ".build/public"
    }
  }
}
